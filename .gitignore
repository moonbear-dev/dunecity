# SourceForge credentials (NEVER commit this!)
scripts/sourceforge-config.sh

# Documentation folders (analysis/ is tracked in dunecity)
documents/

# VSCode settings (ignore user-specific, keep shared config)
.vscode/*
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
dist/
build0/
analysis/

# Imported Micropolis sprites — committed so CI doesn't regenerate each build.
# categories/roads/ is NOT ignored — GFXManager loads road tiles from there.
# composites/ (3x3) are intermediate and not needed at runtime.
imported_sprites/micropolis/categories/*/
!imported_sprites/micropolis/categories/roads/
imported_sprites/micropolis/composites/
imported_sprites/micropolis/composites_special/*.broken

# Local-only scratch / editor files
tmp/
*.code-workspace
